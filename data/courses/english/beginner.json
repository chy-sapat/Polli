          "page": 2,
          "type": "vocabulary",
          "interactive": false,
          "content": {
            "vocab": [
              {
                "word": "reservation",
                "meaning": "An arrangement to keep a room available for you.",
                "examples": ["I have a reservation for tonight."]
              },
              {
                "word": "available",
                "meaning": "Ready to be used or booked.",
                "examples": ["Do you have any rooms available?"]
              },
              {
                "word": "check-in",
                "meaning": "The process of arriving and registering at a hotel.",
                "examples": ["What time is check-in?"]
              }
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-2-page-3",
          "page": 3,
