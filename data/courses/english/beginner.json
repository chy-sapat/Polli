      "id": "english-level-A1-lesson-1",
      "title": "Asking for Directions",
      "description": "Learn how to ask for directions and navigate in English. This lesson covers common phrases for requesting help, understanding street names, and following simple instructions.",
      "contents": [
        {
          "id": "english-level-A1-lesson-1-page-1",
          "page": 1,
          "type": "intro",
          "interactive": false,
          "content": {
            "title": "Asking for Directions",
            "description": "In this lesson, you will learn useful words and sentences for asking and understanding directions."
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-2",
          "page": 2,
          "type": "vocabulary",
          "interactive": false,
          "content": {
            "vocab": [
              {
                "word": "intersection",
                "meaning": "A place where two or more roads meet.",
                "examples": ["Turn left at the intersection."]
              },
              {
                "word": "straight ahead",
                "meaning": "Continue forward without turning.",
                "examples": ["Walk straight ahead for two blocks."]
              },
              {
                "word": "walking distance",
                "meaning": "Close enough to walk to.",
                "examples": ["The hotel is within walking distance."]
              }
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-3",
          "page": 3,
          "type": "interactive_vocab",
          "interactive": true,
          "content": {
            "instruction": "Match the word with its meaning."
          },
          "activity": {
            "activityType": "matching",
            "questions": [
              {
                "word": "intersection",
                "answer": "A place where roads meet"
              },
              {
                "word": "straight ahead",
                "answer": "Continue forward"
              },
              {
                "word": "walking distance",
                "answer": "Close enough to walk"
              }
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-4",
          "page": 4,
          "type": "sentence",
          "interactive": false,
          "content": {
            "pattern": "How do I get to ___?",
            "explanation": "Use this sentence when asking for directions.",
            "examples": [
              "How do I get to the train station?",
              "How do I get to the museum?"
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-5",
          "page": 5,
          "type": "interactive_sentence",
          "interactive": true,
          "content": {
            "instruction": "Complete the sentence."
          },
          "activity": {
            "activityType": "fill_blank",
            "question": "How do I get to the _____ ?",
            "options": ["library", "walk", "turn", "street"],
            "correctAnswer": "library"
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-6",
          "page": 6,
          "type": "sentence",
          "interactive": false,
          "content": {
            "pattern": "Is it within walking distance?",
            "explanation": "Ask whether a place is close enough to walk to.",
            "examples": [
              "Is the station within walking distance?",
              "Is the restaurant within walking distance?"
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-7",
          "page": 7,
          "type": "interactive_sentence",
          "interactive": true,
          "content": {
            "instruction": "Arrange the words into a correct sentence."
          },
          "activity": {
            "activityType": "word_order",
            "words": ["it", "walking", "distance", "within", "is"],
            "correctAnswer": "Is it within walking distance?"
          }
        },

        {
          "id": "english-level-A1-lesson-1-page-8",
          "page": 8,
          "type": "summary",
          "interactive": false,
          "content": {
            "keyVocabulary": [
              "intersection",
              "straight ahead",
              "within walking distance"
            ],
            "keySentences": [
              "How do I get to ___?",
              "Is it within walking distance?"
            ]
          }
        }
      ]
    },
    {
      "id": "english-level-A1-lesson-2",
      "title": "Reserve Hotel Room",
      "description": "Learn how to reserve a hotel room in English. This lesson covers common phrases for making a reservation, asking about amenities, and checking in and out of a hotel.",
      "contents": [
        {
          "id": "english-level-A1-lesson-2-page-1",
          "page": 1,
          "type": "intro",
          "interactive": false,
          "content": {
            "title": "Reserve a Hotel Room",
            "description": "In this lesson, you will learn useful vocabulary and sentences used when booking a hotel room."
          }
