          "activity": {
            "activityType": "matching",
            "questions": [
              {
                "word": "reservation",
                "answer": "A room booking"
              },
              {
                "word": "available",
                "answer": "Ready to be booked"
              },
              {
                "word": "check-in",
                "answer": "Registering at a hotel"
              }
            ]
          }
        },

        {
          "id": "english-level-A1-lesson-2-page-4",
          "page": 4,
          "type": "sentence",
          "interactive": false,
          "content": {
